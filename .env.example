# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Spark Wallet (optional — auto-generated and stored in Supabase on first run)
# Set this to use a specific mnemonic instead of auto-generating one
SPARK_MNEMONIC=
SPARK_NETWORK=MAINNET

# Domain (used for lightning address resolution)
DOMAIN=sats.fast
